{
  "compilerOptions": {
    "target": "es2024",
    "strict": true,
    "lib": ["es2024", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["mocha", "node"],

    "paths": {
      // Since multiple type definitions are provided, specify the definition here to avoid an error.
      "responselike": ["./node_modules/@types/responselike"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "tools/**/*.ts",
    "benchmark/**/*.ts",
    "tsdown.config.ts"
  ]
}
